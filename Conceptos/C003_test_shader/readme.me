# 3️⃣ Shader completo del ojo (estructura profesional)

## eye.glsl

```glsl
#ifdef GL_ES
precision mediump float;
precision mediump int;
#endif

uniform vec2 resolution;
uniform vec2 eyeA;
uniform vec2 eyeB;
uniform vec2 irisC;

uniform float rEye;
uniform float rIris;
uniform float rPupil;

float sdCircle(vec2 p, vec2 c, float r){
    return length(p-c)-r;
}

void main(){

    vec2 p = gl_FragCoord.xy;

    // --- distancias ---
    float dA = sdCircle(p, eyeA, rEye);
    float dB = sdCircle(p, eyeB, rEye);
    float dEye = max(dA,dB);          // párpados

    float dIris = sdCircle(p, irisC, rIris);
    float dPupil = sdCircle(p, irisC, rPupil);

    // --- colores base ---
    vec3 col = vec3(0.95,0.95,0.9);   // fondo

    // dentro del ojo
    if(dEye < 0.0)
        col = vec3(1.0);

    // iris (solo dentro del ojo)
    if(max(dEye,dIris) < 0.0)
        col = vec3(0.2,0.6,0.9);

    // pupila
    if(max(dEye,dPupil) < 0.0)
        col = vec3(0.0);

    // reflejo simple
    float highlight =
        smoothstep(20.0,0.0,
            length(p-(irisC+vec2(-20.0,-20.0))));

    col += highlight*0.8;

    gl_FragColor = vec4(col,1.0);
}
```

---

## Processing

```java
PShader eye;

void setup(){
  size(700,700,P2D);
  eye = loadShader("eye.glsl");
}

void draw(){

  background(240);

  eye.set("resolution",(float)width,(float)height);

  eye.set("eyeA",width/2-120.0,height/2.0);
  eye.set("eyeB",width/2+120.0,height/2.0);

  eye.set("irisC",(float)mouseX,(float)mouseY);

  eye.set("rEye",180.0);
  eye.set("rIris",80.0);
  eye.set("rPupil",30.0);

  shader(eye);
  rect(0,0,width,height);
}
```

